all: rpm

rpm: check
	make rpm

check: build
	make check

build: configure
	make

configure: reconf
	./configure

reconf: style
	autoreconf -i

style: clean
	find . -name xdr -prune -o \( ! -name 'config.h' -name '*.[ch]' \) -print | xargs clang-format --dry-run

clean: pristine
	git clean -f -x -d

pristine:
	git ls-files --other --directory --exclude-standard | sed q1
