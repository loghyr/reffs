		/bin/bash -c "$(call CI_BUILD,--enable-asan --enable-ubsan) && \
			EXTERNAL_DIR=/external \
			/src/scripts/ci_sigmund.sh /build/src/reffsd; \
			rc=\$$?; \
			cp -f /reffs_data/sigmund_results.txt /logs/sigmund_results.txt 2>/dev/null; \
			cp -f /reffs_data/reffsd_sigmund.log /logs/sigmund.log 2>/dev/null; \
			exit \$$rc"

