			cp -f /reffs_data/nfstest_results.txt /logs/nfstest_results.txt 2>/dev/null; \
			cp -f /reffs_data/reffsd_nfstest.log /logs/nfstest.log 2>/dev/null; \
			exit \$$rc"

# -----------------------------------------------------------------------
# krb5: multi-client Kerberos NFS functional test
# -----------------------------------------------------------------------
# nfs_krb5_multiclient owns the entire lifecycle: it starts an
# embedded mini-KDC, spawns a reffsd configured for that realm with a
# krb5 root export, provisions N principals, and forks N krb5 client
# workers.  The CI image (Dockerfile.ci) ships krb5-kdc /
# krb5-admin-server, so the mini-KDC starts here; on an image lacking
# them the driver exits 77 and the script skips cleanly.
#
# QA usage and troubleshooting: docs/krb5-multiclient-testing.md.

krb5: image
	$(DOCKER) run --rm --privileged \
		--ulimit nofile=65536:65536 \
		-v $(ROOT_DIR):/reffs:ro,Z \
		$(CI_IMAGE_NAME) \
		/bin/bash -c "$(call CI_BUILD,--enable-asan --enable-ubsan) && \
			ASAN_OPTIONS=detect_leaks=0 \
			/src/scripts/ci_krb5_multiclient.sh /build/src/reffsd"

# -----------------------------------------------------------------------
# ffv1-stress: pre-push check for scripts/krb5_ffv1_stress.sh
# -----------------------------------------------------------------------
# Self-contained reproducer for the QA-facing stress driver: stands
# up a mini-KDC + a combined-mode reffsd configured for FFv1 + krb5,
# provisions N test principals, runs scripts/krb5_ffv1_stress.sh
# against them, asserts every worker passes.  Distinct from `krb5`,
# which exercises plain MDS I/O via nfs_krb5_multiclient; this one
# exercises the LAYOUTGET + DS I/O path that krb5_ffv1_stress.sh
# actually drives in the field.
#
# EXPECTED RED until #60 is fixed (heap-use-after-free in
# ec_disconnect_all surfaces in the DS-side teardown after a
# successful LAYOUTGET).  See test_krb5_ffv1_stress_local.sh for
# the full context; the script under test is fine, the failure is
# in the reffs client library.

ffv1-stress: image
	$(DOCKER) run --rm --privileged \
		--ulimit nofile=65536:65536 \
		-v $(ROOT_DIR):/reffs:ro,Z \
		$(CI_IMAGE_NAME) \
		/bin/bash -c "$(call CI_BUILD,--enable-asan --enable-ubsan) && \
			ASAN_OPTIONS=detect_leaks=0 \
			/src/scripts/test_krb5_ffv1_stress_local.sh /build/src/reffsd"

# -----------------------------------------------------------------------
# mirror: end-to-end functional check for FFV2_ENCODING_MIRRORED
# -----------------------------------------------------------------------
# Stands up a combined-mode reffsd with N loopback dstores so the
# MDS allocates N mirrors per layout, then runs ec_demo
# `write` + `verify` (+ a degraded `verify` with one mirror
# skipped) against it with --encoding mirror --k N --m 0.  Asserts
# every invocation exits 0 -- the data fans out via CHUNK_WRITE
# to N replicas, is readable back via CHUNK_READ from any present
# replica, and byte-compares identical to the input.
#
# Wired but not run by default; the `check` and `full` targets do
# not exercise the MIRROR pipeline path.  Run explicitly via
# `make -f Makefile.ci mirror`.

mirror: image
	$(DOCKER) run --rm --privileged \
		--ulimit nofile=65536:65536 \
		-v $(ROOT_DIR):/reffs:ro,Z \
		$(CI_IMAGE_NAME) \
		/bin/bash -c "$(call CI_BUILD,--enable-asan --enable-ubsan) && \
			ASAN_OPTIONS=detect_leaks=0 \
			/src/scripts/test_mirror_local.sh /build/src/reffsd"

