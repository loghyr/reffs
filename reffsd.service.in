[Unit]
Description=Reffs NFS Daemon
Wants=network-online.target
After=network-online.target rpcbind.service

[Service]
Environment="LIBC_FATAL_STDERR_=1"
Environment="MALLOC_CONF=prof:false"
ExecStart=/usr/bin/reffsd
LimitCORE=infinity
SyslogIdentifier=reffsd

[Install]
WantedBy=multi-user.target
