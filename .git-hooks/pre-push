#
# reffs pre-push hook -- style + license only (default).
#
# Build / unit / integration coverage runs in CI (reffs.ci nightly,
# garbo) and via `make -f Makefile.reffs ci-check` on demand.  The
# pre-push hook stays scoped to the two checks that are cheap, fast,
# and consistently catch human-introduced drift (clang-format and
# SPDX header compliance).
#
# A heavier sibling variant `.git-hooks/pre-push.ci` runs the full
# Docker check-ci pipeline (build + unit + integration); use that
# when CI feedback is too slow to wait for.  See its header for how
# to install it as the active hook.
#
# Install (pick one):
#   cp .git-hooks/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push
#   git config core.hooksPath .git-hooks   # versioned, applies all hooks in dir

set -e

echo "[pre-push] make -f Makefile.reffs style ..."
make -f Makefile.reffs style

echo "[pre-push] make -f Makefile.reffs license ..."
make -f Makefile.reffs license

echo "[pre-push] PASS"
