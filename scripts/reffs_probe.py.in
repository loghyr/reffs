import sys
import os
import argparse
import argcomplete
import struct
import time

# Try both naming conventions to handle both local and installed versions
try:
    # First try the installed package path
    from reffs.probe1_xdr_type import *
    from reffs.probe1_xdr_const import *
    from reffs.probe_client import Probe1Client
except ModuleNotFoundError:
    # If that fails, try the local development path
    script_dir = os.path.dirname(os.path.abspath(__file__))
    if script_dir not in sys.path:
        sys.path.insert(0, script_dir)

    # Make sure __init__.py exists
    init_file = os.path.join(script_dir, "reffs", "__init__.py")
    if not os.path.exists(init_file):
        with open(init_file, 'w') as f:
            pass  # Create empty file

    # Try with the XDR naming convention
    from reffs.probe1_xdr_type import *
    from reffs.probe1_xdr_const import *
    from reffs.probe_client import Probe1Client

PROGRAM_MAP = {
    100003: 'nfs',
    100005: 'mount',
    211768: 'probe'
}

PROGRAM_NAME_TO_ID = {name: id for id, name in PROGRAM_MAP.items()}

TRACE_CAT_MAP = {
    PROBE1_TRACE_CAT_GENERAL: 'general',
    PROBE1_TRACE_CAT_IO: 'io',
    PROBE1_TRACE_CAT_RPC: 'rpc',
    PROBE1_TRACE_CAT_NFS: 'nfs',
    PROBE1_TRACE_CAT_FS: 'fs',
    PROBE1_TRACE_CAT_ALL: 'all'
}

TRACE_CAT_NAME_TO_ID = {name: id for id, name in TRACE_CAT_MAP.items()}

def probe_error_handler(ret):
    if ret == PROBE1_OK:
        return

    print(f'Error: {ret}')
    sys.exit(ret)


def probe_null(client, args):
    res = client.probe_null()
    print("Null procedure completed successfully")


def print_stats(pp, args):
    print(f'{"OP":<10} {"Name":<15} {"Calls":<10} {"Errors":<10} {"Max Duration":<15} {"Total Duration":<15} {"Average Duration":<15}')

    for po in sorted(pp.pp_ops, key=lambda po: po.po_op):
        if po.po_calls:
            avg_dur = po.po_total_duration / po.po_calls
        else:
            avg_dur = 0
        print(f'{po.po_op:<10} {po.po_name.decode():<15} {po.po_calls:<10} {po.po_errors:<10} {po.po_max_duration:<15} {po.po_total_duration:<15} {avg_dur:<15}')

    if args.histogram:
        print("\n--- Histogram Data (Counts) ---")
        print(f"\n{'OP':<5} {'Name':<15} {'<1ms':<10} {'1-10ms':<10} {'10-100ms':<10} {'100ms-1s':<10} {'1-10s':<10} {'≥10s':<10}")

        for po in sorted(pp.pp_ops, key=lambda po: po.po_op):
            if po.po_calls > 0:  # Only show operations that were called
                print(f'{po.po_op:<5} '
                      f'{po.po_name.decode():<15} '
                      f'{po.po_bucket_1ms:<10} '
                      f'{po.po_bucket_10ms:<10} '
                      f'{po.po_bucket_100ms:<10} '
                      f'{po.po_bucket_1s:<10} '
                      f'{po.po_bucket_10s:<10} '
                      f'{po.po_bucket_rest:<10}')

    if args.percentages:
        print("\n--- Histogram Data (Percentages) ---")
        print(f"\n{'OP':<5} {'Name':<15} {'<1ms':<10} {'1-10ms':<10} {'10-100ms':<10} {'100ms-1s':<10} {'1-10s':<10} {'≥10s':<10}")

        for po in sorted(pp.pp_ops, key=lambda po: po.po_op):
            if po.po_calls > 0:  # Only show operations that were called
                total = po.po_calls

                # Calculate percentages
                pct_1ms = (po.po_bucket_1ms / total) * 100
                pct_10ms = (po.po_bucket_10ms / total) * 100
                pct_100ms = (po.po_bucket_100ms / total) * 100
                pct_1s = (po.po_bucket_1s / total) * 100
                pct_10s = (po.po_bucket_10s / total) * 100
                pct_rest = (po.po_bucket_rest / total) * 100

                print(f'{po.po_op:<5} '
                      f'{po.po_name.decode():<15} '
                      f'{pct_1ms:6.1f}% '
                      f'{pct_10ms:6.1f}% '
                      f'{pct_100ms:6.1f}% '
                      f'{pct_1s:6.1f}% '
                      f'{pct_10s:6.1f}% '
                      f'{pct_rest:6.1f}%')

    if args.histogram or args.percentages:
        print("\n--- Percentile Statistics (ns) ---")
        print(f"\n{'OP':<5} {'Name':<15} {'Min':<15} {'Median':<15} {'90th':<15} {'99th':<15} {'99.9th':<15} {'Max':<15} {'Mean':<15}")

        for po in sorted(pp.pp_ops, key=lambda po: po.po_op):
            if po.po_calls > 0:
                print(f'{po.po_op:<5} '
                      f'{po.po_name.decode():<15} '
                      f'{po.po_min_ns:<15} '
                      f'{po.po_median_ns:<15} '
                      f'{po.po_p90_ns:<15} '
                      f'{po.po_p99_ns:<15} '
                      f'{po.po_p999_ns:<15} '
                      f'{po.po_max_ns:<15} '
                      f'{po.po_mean_ns:<15}')


def stats_gather(client, args):
    if args.program_id:
        program_id = args.program_id
    elif args.program_name:
        program_id = PROGRAM_NAME_TO_ID[args.program_name]

    res = client.stats_gather(program_id, args.version)
    probe_error_handler(res.psgr_status)

    pp = res.psgr_resok.psgr_program

    print(f'Reply Errors = {pp.pp_replied_errors}')
    print(f'Reject Errors = {pp.pp_rejected_errors}')
    print(f'Accept Errors = {pp.pp_accepted_errors}')
    print(f'Auth Errors = {pp.pp_authed_errors}')

    print_stats(pp, args)


def context(client, args):
    res = client.context()
    probe_error_handler(res.pcr_status)

    resok = res.pcr_resok

    print(f'Created          = {resok.pcr_created}')
    print(f'Freed            = {resok.pcr_freed}')
    print(f'Active Cancelled = {resok.pcr_active_cancelled}')
    print(f'Active Destroyed = {resok.pcr_active_destroyed}')
    print(f'Cancelled Freed  = {resok.pcr_cancelled_freed}')
    print(f'Destroyed Freed  = {resok.pcr_destroyed_freed}')


def rpc_dump_set(client, args):
    res = client.rpc_dump_set(args.dump)
    probe_error_handler(res)


def trace_set(client, args):
    category = TRACE_CAT_NAME_TO_ID[args.category]
    res = client.trace_set(category, args.tracing)
    probe_error_handler(res)


def print_trace_categories(trace_list):
    print(f"{'Category':<10} {'Status':<6}")
    print("-" * 17)
    for trace in sorted(trace_list, key=lambda t: t.ptl_cat):
        category_name = TRACE_CAT_MAP.get(trace.ptl_cat, "unknown")
        status = "Set" if trace.ptl_set else "Unset"
        print(f"{category_name:<10} {status:<6}")

def traces_list(client, args):
    category = TRACE_CAT_NAME_TO_ID[args.category]
    res = client.traces_list(category)
    probe_error_handler(res.tlr_status)

    print_trace_categories(res.tlr_resok.tlr_list)


def parse_args():
    parser = argparse.ArgumentParser(description='Probe reffs servers')

    parser.add_argument('--port',
                        help=f'set port, default is {PROBE_PORT}',
                        required=False,
                        type=int,
                        default=PROBE_PORT)
    parser.add_argument('--host',
                        help='set host, default is ::1',
                        required=False,
                        default='::1')
    parser.add_argument('--time',
                        help='Time the call',
                        required=False,
                        action='store_true',
                        default=False)

    subparsers = parser.add_subparsers(help='sub-command help', dest='command')
    subparsers.required = True  # Make subcommand required

    p_null = subparsers.add_parser('null',
                                   help='Ping the server')
    p_null.set_defaults(func=probe_null)

    p_gather = subparsers.add_parser('stats-gather',
                                     help='Gather stats for an RPC program')
    a_program = p_gather.add_mutually_exclusive_group(required=True)

    a_program.add_argument('--program-id',
                           dest='program_id',
                           type=int,
                           choices=list(PROGRAM_MAP.keys()),
                           help=f'Program id to gather stats (options: {", ".join(map(str, PROGRAM_MAP.keys()))})')

    a_program.add_argument('--program-name',
                           dest='program_name',
                           type=str,
                           choices=list(PROGRAM_MAP.values()),
                           help=f'Program name to gather stats (options: {", ".join(PROGRAM_MAP.values())})')

    p_gather.add_argument('--version',
                          dest='version',
                          required=True,
                          type=int,
                          help='Program version to gather stats')

    p_gather.add_argument('--histogram',
                          dest='histogram',
                          action='store_true',
                          help='Display the histogram (default is not to show)')

    p_gather.add_argument('--percentages',
                          dest='percentages',
                          action='store_true',
                          help='Display histogram data as percentages (default is not to show)')

    p_gather.set_defaults(func=stats_gather, histogram=False)

    p_context = subparsers.add_parser('context',
                                      help='Get the context stats')
    p_context.set_defaults(func=context)

    p_rpc_dump_set = subparsers.add_parser('rpc-dump',
                                           help='Dump RPC packets')
    a_dumper = p_rpc_dump_set.add_mutually_exclusive_group(required=True)
    a_dumper.add_argument('--set',
                          help='Set RPC dumping',
                          dest='dump',
                          required=False,
                          action='store_true')
    a_dumper.add_argument('--unset',
                          help='Unset RPC dumping',
                          dest='dump',
                          required=False,
                          action='store_false')
    p_rpc_dump_set.set_defaults(func=rpc_dump_set)

    p_trace_set = subparsers.add_parser('trace-set',
                                        help='Set the tracing for a category')
    a_trace_set = p_trace_set.add_mutually_exclusive_group(required=True)
    a_trace_set.add_argument('--set',
                             help='Set TRACE category tracing',
                             dest='tracing',
                             required=False,
                             action='store_true')
    a_trace_set.add_argument('--unset',
                             help='Unset TRACE category tracing',
                             dest='tracing',
                             required=False,
                             action='store_false')
    p_trace_set.add_argument('--category',
                             type=str,
                             choices=list(TRACE_CAT_MAP.values()),
                             help=f'Category name to set tracing (options: {", ".join(TRACE_CAT_MAP.values())})')
    p_trace_set.set_defaults(func=trace_set)

    p_traces_list = subparsers.add_parser('traces-list',
                                          help='List the tracing for a category')
    p_traces_list.add_argument('--category',
                              type=str,
                              choices=list(TRACE_CAT_MAP.values()),
                              help=f'Category name to list tracing (options: {", ".join(TRACE_CAT_MAP.values())})')
    p_traces_list.set_defaults(func=traces_list)

    argcomplete.autocomplete(parser)
    return parser.parse_args()


def main():
    args = parse_args()

    # Added check for function attribute
    if not hasattr(args, 'func'):
        print("Error: No command specified")
        sys.exit(1)

    # Time measurement
    ts = None
    if args.time:
        ts = time.time()

    # Execute the requested function
    args.func(Probe1Client(args.host, args.port), args)

    # Print duration if timing was requested
    if args.time:
        te = time.time()
        duration = te - ts
        print(f'Time elapsed: {duration:.2f} seconds')

if __name__ == '__main__':
    main()
