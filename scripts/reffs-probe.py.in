    print_fd_infos(res.filr_resok.filr_pf)


def format_size(size_bytes, human_readable=False):
    if not human_readable:
        return str(size_bytes)

    if size_bytes == 0:
        return "0B"

    units = ["B", "K", "M", "G", "T", "P", "E"]
    i = 0
    size = float(size_bytes)

    while size >= 1024 and i < len(units) - 1:
        size /= 1024.0
        i += 1

    # Match typical du -h style formatting
    if size >= 10 or size.is_integer():
        return f"{int(size)}{units[i]}"
    else:
        return f"{size:.1f}{units[i]}"


def print_nfs4_op_stats(ops):
    print(f'{"OP":<5} {"Name":<25} {"Calls":<10} {"Errors":<10} '
          f'{"BytesIn":<12} {"BytesOut":<12} {"TotalDur(ns)":<16} {"MaxDur(ns)":<16}')
    print("-" * 110)
    for pno in sorted(ops, key=lambda o: o.pno_op):
        if not pno.pno_calls:
            continue
        name = pno.pno_name.decode() if isinstance(pno.pno_name, bytes) else pno.pno_name
        print(f'{pno.pno_op:<5} {name:<25} {pno.pno_calls:<10} {pno.pno_errors:<10} '
              f'{pno.pno_bytes_in:<12} {pno.pno_bytes_out:<12} '
              f'{pno.pno_duration_total:<16} {pno.pno_duration_max:<16}')


def nfs4_op_stats(client, args):
