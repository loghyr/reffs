# Try both naming conventions to handle both local and installed versions
script_dir = os.path.dirname(os.path.abspath(__file__))
local_reffs = os.path.join(script_dir, "reffs")

# Prioritize local development path if it exists
if os.path.isdir(local_reffs):
    if script_dir not in sys.path:
        sys.path.insert(0, script_dir)
    # Make sure __init__.py exists
    init_file = os.path.join(local_reffs, "__init__.py")
    if not os.path.exists(init_file):
        with open(init_file, 'w') as f:
            pass  # Create empty file

try:
    from reffs.probe1_xdr_type import *
    from reffs.probe1_xdr_const import *
    from reffs.probe_client import Probe1Client
except ImportError:
    # Fallback to installed version if local not found or failed
    try:
        from reffs.probe1_xdr_type import *
        from reffs.probe1_xdr_const import *
        from reffs.probe_client import Probe1Client
    except ImportError:
        print("Error: Could not import reffs package. Make sure it is installed or in the current directory.")
        sys.exit(1)

