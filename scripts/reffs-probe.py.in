context_state_all = (PROBE1_IO_CONTEXT_ENTRY_STATE_ACTIVE |
                     PROBE1_IO_CONTEXT_ENTRY_STATE_MARKED_DESTROYED |
                     PROBE1_IO_CONTEXT_ENTRY_STATE_PENDING_FREE)

CONTEXT_STATE_MAP = {
    PROBE1_IO_CONTEXT_ENTRY_STATE_ACTIVE : 'active',
    PROBE1_IO_CONTEXT_ENTRY_STATE_MARKED_DESTROYED : 'destroyed',
    PROBE1_IO_CONTEXT_ENTRY_STATE_PENDING_FREE : 'pending',
    context_state_all : 'all'
}

CONTEXT_STATE_NAME_TO_ID = {name: id for id, name in CONTEXT_STATE_MAP.items()}

def xdr_to_dict(obj):
    """
    Recursively convert XDR objects to dictionaries, stripping prefixes.
    """
    if isinstance(obj, list):
        return [xdr_to_dict(item) for item in obj]
    if isinstance(obj, dict):
        return {key: xdr_to_dict(value) for key, value in obj.items()}
    if hasattr(obj, '__dict__'):
        res = {}
        for key, value in obj.__dict__.items():
            # Skip internal XDR state
            if key.startswith('_'):
                continue

            # Strip XDR prefix (e.g., pcr_created -> created)
            new_key = key
            if '_' in key:
                parts = key.split('_', 1)
                # Heuristic: prefix is usually 2-4 lowercase chars
                if 2 <= len(parts[0]) <= 4 and parts[0].islower():
                     new_key = parts[1]

            res[new_key] = xdr_to_dict(value)
        return res
    if isinstance(obj, bytes):
        return obj.decode('utf-8', errors='replace').rstrip('\x00')
    return obj


def json_output(data):
    print(json.dumps(xdr_to_dict(data), indent=4))


def probe_error_handler(ret):
    if ret == PROBE1_OK:
        return

    print(f'Error: {ret}')
    sys.exit(ret)


def probe_null(client, args):
    res = client.probe_null()
    if args.json:
        json_output({"status": "OK"})
        return
    print("Null procedure completed successfully")


def print_stats(pp, args):
    print(f'{"OP":<10} {"Name":<15} {"Calls":<10} {"Errors":<10} {"Max Duration":<15} {"Total Duration":<15} {"Average Duration":<15}')

    for po in sorted(pp.pp_ops, key=lambda po: po.po_op):
        if po.po_calls:
            avg_dur = po.po_total_duration / po.po_calls
        else:
            avg_dur = 0
        print(f'{po.po_op:<10} {po.po_name.decode():<15} {po.po_calls:<10} {po.po_errors:<10} {po.po_max_duration:<15} {po.po_total_duration:<15} {avg_dur:<15}')

    if args.histogram:
        print("\n--- Histogram Data (Counts) ---")
        print(f"\n{'OP':<5} {'Name':<15} {'<1ms':<10} {'1-10ms':<10} {'10-100ms':<10} {'100ms-1s':<10} {'1-10s':<10} {'≥10s':<10}")

        for po in sorted(pp.pp_ops, key=lambda po: po.po_op):
            if po.po_calls > 0:  # Only show operations that were called
                print(f'{po.po_op:<5} '
                      f'{po.po_name.decode():<15} '
                      f'{po.po_bucket_1ms:<10} '
                      f'{po.po_bucket_10ms:<10} '
                      f'{po.po_bucket_100ms:<10} '
                      f'{po.po_bucket_1s:<10} '
                      f'{po.po_bucket_10s:<10} '
                      f'{po.po_bucket_rest:<10}')

    if args.percentages:
        print("\n--- Histogram Data (Percentages) ---")
        print(f"\n{'OP':<5} {'Name':<15} {'<1ms':<10} {'1-10ms':<10} {'10-100ms':<10} {'100ms-1s':<10} {'1-10s':<10} {'≥10s':<10}")

        for po in sorted(pp.pp_ops, key=lambda po: po.po_op):
            if po.po_calls > 0:  # Only show operations that were called
                total = po.po_calls

                # Calculate percentages
                pct_1ms = (po.po_bucket_1ms / total) * 100
                pct_10ms = (po.po_bucket_10ms / total) * 100
                pct_100ms = (po.po_bucket_100ms / total) * 100
                pct_1s = (po.po_bucket_1s / total) * 100
                pct_10s = (po.po_bucket_10s / total) * 100
                pct_rest = (po.po_bucket_rest / total) * 100

                print(f'{po.po_op:<5} '
                      f'{po.po_name.decode():<15} '
                      f'{pct_1ms:6.1f}% '
                      f'{pct_10ms:6.1f}% '
                      f'{pct_100ms:6.1f}% '
                      f'{pct_1s:6.1f}% '
                      f'{pct_10s:6.1f}% '
                      f'{pct_rest:6.1f}%')

    if args.histogram or args.percentages:
        print("\n--- Percentile Statistics (ns) ---")
        print(f"\n{'OP':<5} {'Name':<15} {'Min':<15} {'Median':<15} {'90th':<15} {'99th':<15} {'99.9th':<15} {'Max':<15} {'Mean':<15}")

        for po in sorted(pp.pp_ops, key=lambda po: po.po_op):
            if po.po_calls > 0:
                print(f'{po.po_op:<5} '
                      f'{po.po_name.decode():<15} '
                      f'{po.po_min_ns:<15} '
                      f'{po.po_median_ns:<15} '
                      f'{po.po_p90_ns:<15} '
                      f'{po.po_p99_ns:<15} '
                      f'{po.po_p999_ns:<15} '
                      f'{po.po_max_ns:<15} '
                      f'{po.po_mean_ns:<15}')


def stats_gather(client, args):
    if args.program_id:
        program_id = args.program_id
    elif args.program_name:
        program_id = PROGRAM_NAME_TO_ID[args.program_name]

    res = client.stats_gather(program_id, args.version)
    probe_error_handler(res.psgr_status)

    if args.json:
        json_output(res.psgr_resok.psgr_program)
        return

    pp = res.psgr_resok.psgr_program

    print(f'Reply Errors = {pp.pp_replied_errors}')
    print(f'Reject Errors = {pp.pp_rejected_errors}')
    print(f'Accept Errors = {pp.pp_accepted_errors}')
    print(f'Auth Errors = {pp.pp_authed_errors}')

    print_stats(pp, args)


