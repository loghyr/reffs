    probe_error_handler(res.nosr_status)

    if args.json:
        json_output(res.nosr_resok.nosr_ops)
        return

    print_nfs4_op_stats(res.nosr_resok.nosr_ops)


def print_layout_error_table(title, entries):
    print(f'\n{title}:')
    print(f'{"ID":<8} {"Name":<20} {"Total":<10} {"Access":<10} {"IO":<10} {"Other":<10}')
    print("-" * 68)
    for e in entries:
        name = e.ple_name.decode() if isinstance(e.ple_name, bytes) else e.ple_name
        print(f'{e.ple_id:<8} {name:<20} {e.ple_total:<10} {e.ple_access:<10} {e.ple_io:<10} {e.ple_other:<10}')


def layout_errors(client, args):
    res = client.layout_errors()
    probe_error_handler(res.ler_status)

    resok = res.ler_resok

    if args.json:
        out = {
            'global': {
                'total': resok.ler_global.ple_total,
                'access': resok.ler_global.ple_access,
                'io': resok.ler_global.ple_io,
                'other': resok.ler_global.ple_other,
            },
            'dstores': [{
                'id': d.ple_id,
                'name': d.ple_name.decode() if isinstance(d.ple_name, bytes) else d.ple_name,
                'total': d.ple_total, 'access': d.ple_access,
                'io': d.ple_io, 'other': d.ple_other,
            } for d in resok.ler_dstores],
            'clients': [{
                'id': c.ple_id,
                'name': c.ple_name.decode() if isinstance(c.ple_name, bytes) else c.ple_name,
                'total': c.ple_total, 'access': c.ple_access,
                'io': c.ple_io, 'other': c.ple_other,
            } for c in resok.ler_clients],
        }
        print(json.dumps(out, indent=2))
        return

    g = resok.ler_global
    print(f'Layout Errors (global): total={g.ple_total} access={g.ple_access} io={g.ple_io} other={g.ple_other}')

    if resok.ler_dstores:
        print_layout_error_table('Per-Dstore', resok.ler_dstores)

    if resok.ler_clients:
        print_layout_error_table('Per-Client', resok.ler_clients)


def fs_usage(client, args):
    res = client.fs_usage()
    probe_error_handler(res.fur_status)

    resok = res.fur_resok

    if args.json:
        json_output(resok)
        return

    hr = args.human_readable

    mount_stats = None
    if args.mount_path:
        try:
            import os
            sv = os.statvfs(args.mount_path)
            mount_stats = {
                'total_bytes': sv.f_blocks * sv.f_frsize,
                'free_bytes': sv.f_bavail * sv.f_frsize,
                'used_bytes': (sv.f_blocks - sv.f_bfree) * sv.f_frsize,
                'total_files': sv.f_files,
                'free_files': sv.f_ffree,
                'used_files': sv.f_files - sv.f_ffree
            }
        except Exception as e:
            print(f"Warning: Could not get stats for mount path {args.mount_path}: {e}")

    if mount_stats:
        header = f"{'Metric':<15} {'Server (RPC)':>20} {'Mount (statvfs)':>20} {'Diff':>15}"
        print(header)
        print("-" * len(header))

        metrics = [
            ('Total Bytes', resok.fur_total_bytes, mount_stats['total_bytes'], True),
            ('Used Bytes', resok.fur_used_bytes, mount_stats['used_bytes'], True),
            ('Free Bytes', resok.fur_free_bytes, mount_stats['free_bytes'], True),
            ('Total Inodes', resok.fur_total_files, mount_stats['total_files'], False),
            ('Used Inodes', resok.fur_used_files, mount_stats['used_files'], False),
            ('Free Inodes', resok.fur_free_files, mount_stats['free_files'], False),
        ]

        for label, r_val, m_val, is_bytes in metrics:
            r_str = format_size(r_val, hr if is_bytes else False)
            m_str = format_size(m_val, hr if is_bytes else False)
            diff = r_val - m_val
            diff_str = format_size(diff, hr if is_bytes else False)
            print(f"{label:<15} {r_str:>20} {m_str:>20} {diff_str:>15}")
    else:
        print("Filesystem Usage (Internal/External):")
        print("  Bytes:")
        print(f"    Total: {format_size(resok.fur_total_bytes, hr):>15}")
        print(f"    Used:  {format_size(resok.fur_used_bytes, hr):>15}")
        print(f"    Free:  {format_size(resok.fur_free_bytes, hr):>15}")
        print("  Inodes:")
        print(f"    Total: {resok.fur_total_files:>15}")
        print(f"    Used:  {resok.fur_used_files:>15}")
        print(f"    Free:  {resok.fur_free_files:>15}")


# ----------------------------------------------------------------
# Superblock management command handlers
# ----------------------------------------------------------------

def format_uuid(raw):
    """Format 16 raw bytes as a UUID string."""
    import uuid as _uuid
    if isinstance(raw, (bytes, bytearray)) and len(raw) == 16:
        return str(_uuid.UUID(bytes=bytes(raw)))
    return str(raw)


def format_sb_info(sb):
    """Format a probe_sb_info1 for display."""
    path = sb.psi_path if isinstance(sb.psi_path, str) else sb.psi_path.decode('utf-8', errors='replace')
    state = SB_LIFECYCLE_MAP.get(sb.psi_state, str(sb.psi_state))
    stype = STORAGE_TYPE_MAP.get(sb.psi_storage_type, str(sb.psi_storage_type))
    flavors = [AUTH_FLAVOR_MAP.get(f, str(f)) for f in sb.psi_flavors]
    return path, state, stype, flavors


def sb_list_cmd(client, args):
    res = client.sb_list()
    probe_error_handler(res.slr_status)
    sbs = res.slr_resok.slr_sbs
    print(f"{'ID':<6} {'UUID':<38} {'Path':<24} {'State':<12} {'Flavors'}")
    print(f"{'--':<6} {'----':<38} {'----':<24} {'-----':<12} {'-------'}")
    for sb in sbs:
        path, state, stype, flavors = format_sb_info(sb)
        flav_str = ','.join(flavors) if flavors else '(none)'
        sb_uuid = format_uuid(sb.psi_uuid) if hasattr(sb, 'psi_uuid') else 'n/a'
        print(f"{sb.psi_id:<6} {sb_uuid:<38} {path:<24} {state:<12} {flav_str}")


def sb_create_cmd(client, args):
    storage = STORAGE_TYPE_NAME_TO_ID.get(args.storage, PROBE1_STORAGE_RAM)
    res = client.sb_create(args.path, storage)
    probe_error_handler(res.scr_status)
    sb = res.scr_resok
    path, state, stype, flavors = format_sb_info(sb)
    sb_uuid = format_uuid(sb.psi_uuid) if hasattr(sb, 'psi_uuid') else 'n/a'
    print(f"Created superblock {sb.psi_id}: uuid={sb_uuid} path={path} state={state} storage={stype}")


def sb_mount_cmd(client, args):
    res = client.sb_mount(args.id, args.path)
    probe_error_handler(res)
    print(f"Superblock {args.id} mounted at {args.path}")


def sb_unmount_cmd(client, args):
    res = client.sb_unmount(args.id)
    probe_error_handler(res)
    print(f"Superblock {args.id} unmounted")


def sb_destroy_cmd(client, args):
    res = client.sb_destroy(args.id)
    probe_error_handler(res)
    print(f"Superblock {args.id} destroyed")


def sb_get_cmd(client, args):
    res = client.sb_get(args.id)
    probe_error_handler(res.sgr_status)
    sb = res.sgr_resok
    path, state, stype, flavors = format_sb_info(sb)
    flav_str = ','.join(flavors) if flavors else '(none)'
    sb_uuid = format_uuid(sb.psi_uuid) if hasattr(sb, 'psi_uuid') else 'n/a'
    print(f"Superblock {sb.psi_id}:")
    print(f"  UUID:     {sb_uuid}")
    print(f"  Path:     {path}")
    print(f"  State:    {state}")
    print(f"  Storage:  {stype}")
    print(f"  Flavors:  {flav_str}")
    print(f"  Bytes:    {sb.psi_bytes_used} / {sb.psi_bytes_max}")
    print(f"  Inodes:   {sb.psi_inodes_used} / {sb.psi_inodes_max}")


def sb_set_flavors_cmd(client, args):
    flavors = [AUTH_FLAVOR_NAME_TO_ID[f] for f in args.flavors]
    res = client.sb_set_flavors(args.id, flavors)
    probe_error_handler(res)
    print(f"Superblock {args.id} flavors set to: {','.join(args.flavors)}")


def sb_lint_flavors_cmd(client, args):
    res = client.sb_lint_flavors()
    probe_error_handler(res.lfr_status)
    resok = res.lfr_resok
    if resok.lfr_warnings == 0:
        print("Flavor consistency check: OK (0 warnings)")
    else:
        print(f"Flavor consistency check: {resok.lfr_warnings} warning(s)")


ID_TYPE_MAP = {
    0: 'unix',
    1: 'sid',
    2: 'krb5',
    3: 'name',
    4: 'synth',
    15: 'nobody',
}


def identity_domain_list_cmd(client, args):
    res = client.identity_domain_list()
    probe_error_handler(res.idl_status)
    resok = res.idl_resok
    domains = resok.idl_domains
    if not domains:
        print('No identity domains')
        return
    print(f'{"Index":>5}  {"Type":>8}  Name')
    print(f'{"-----":>5}  {"--------":>8}  ----')
    for d in domains:
        type_name = ID_TYPE_MAP.get(d.pid_type, f'unknown({d.pid_type})')
        name = d.pid_name.decode('utf-8', errors='replace') if isinstance(d.pid_name, bytes) else d.pid_name
        print(f'{d.pid_index:>5}  {type_name:>8}  {name}')


def identity_map_list_cmd(client, args):
    res = client.identity_map_list()
    probe_error_handler(res.iml_status)
    resok = res.iml_resok
    mappings = resok.iml_mappings
    if not mappings:
        print('No identity mappings')
        return
    print(f'{"From":>20}  {"To":>20}  Name')
    print(f'{"----":>20}  {"--":>20}  ----')
    for m in mappings:
        name = m.pim_name.decode('utf-8', errors='replace') if isinstance(m.pim_name, bytes) else m.pim_name
        print(f'0x{m.pim_from:016x}  0x{m.pim_to:016x}  {name}')


def identity_map_remove_cmd(client, args):
    from_id = int(args.from_id, 0)
    res = client.identity_map_remove(from_id)
    probe_error_handler(res)
    print(f'Mapping 0x{from_id:016x} removed')


def parse_args():
    parser = argparse.ArgumentParser(description='Probe reffs servers')

    parser.add_argument('--port',
                        help=f'set port, default is {PROBE_PORT}',
                        required=False,
                        type=int,
                        default=PROBE_PORT)
    parser.add_argument('--host',
                        help='set host, default is ::1',
                        required=False,
                        default='::1')
    parser.add_argument('-H', '--human',
                        help='Human readable output',
                        required=False,
                        action='store_true',
                        default=False)
    parser.add_argument('-j', '--json',
                        help='Output in JSON format',
                        required=False,
                        action='store_true',
                        default=False)
    parser.add_argument('--time',
                        help='Time the call',
                        required=False,
                        action='store_true',
                        default=False)

    subparsers = parser.add_subparsers(help='sub-command help', dest='command')

    subparsers.required = True  # Make subcommand required

    p_null = subparsers.add_parser('null',
                                   help='Ping the server')
    p_null.set_defaults(func=probe_null)

    p_gather = subparsers.add_parser('stats-gather',
                                     help='Gather stats for an RPC program')
    a_program = p_gather.add_mutually_exclusive_group(required=True)

    a_program.add_argument('--program-id',
                           dest='program_id',
                           type=int,
                           choices=list(PROGRAM_MAP.keys()),
                           help=f'Program id to gather stats (options: {", ".join(map(str, PROGRAM_MAP.keys()))})')

    a_program.add_argument('--program-name',
                           dest='program_name',
                           type=str,
                           choices=list(PROGRAM_MAP.values()),
                           help=f'Program name to gather stats (options: {", ".join(PROGRAM_MAP.values())})')

    p_gather.add_argument('--version',
                          dest='version',
                          required=True,
                          type=int,
                          help='Program version to gather stats')

    p_gather.add_argument('--histogram',
                          dest='histogram',
                          action='store_true',
                          help='Display the histogram (default is not to show)')

    p_gather.add_argument('--percentages',
                          dest='percentages',
                          action='store_true',
                          help='Display histogram data as percentages (default is not to show)')

    p_gather.set_defaults(func=stats_gather, histogram=False)

    p_context = subparsers.add_parser('context',
                                      help='Get the context stats')
    p_context.set_defaults(func=context)

    p_rpc_dump_set = subparsers.add_parser('rpc-dump',
                                           help='Dump RPC packets')
    a_dumper = p_rpc_dump_set.add_mutually_exclusive_group(required=True)
    a_dumper.add_argument('--set',
                          help='Set RPC dumping',
                          dest='dump',
                          required=False,
                          action='store_true')
    a_dumper.add_argument('--unset',
                          help='Unset RPC dumping',
                          dest='dump',
                          required=False,
                          action='store_false')
    p_rpc_dump_set.set_defaults(func=rpc_dump_set)

    p_trace_set = subparsers.add_parser('trace-set',
                                        help='Set the tracing for a category')
    a_trace_set = p_trace_set.add_mutually_exclusive_group(required=True)
    a_trace_set.add_argument('--set',
                             help='Set TRACE category tracing',
                             dest='tracing',
                             required=False,
                             action='store_true')
    a_trace_set.add_argument('--unset',
                             help='Unset TRACE category tracing',
                             dest='tracing',
                             required=False,
                             action='store_false')
    p_trace_set.add_argument('--category',
                             type=str,
                             choices=list(TRACE_CAT_MAP.values()),
                             help=f'Category name to set tracing (options: {", ".join(TRACE_CAT_MAP.values())})')
    p_trace_set.set_defaults(func=trace_set)

    p_traces_list = subparsers.add_parser('traces-list',
                                          help='List the tracing for a category')
    p_traces_list.add_argument('--category',
                              type=str,
                              choices=list(TRACE_CAT_MAP.values()),
                              help=f'Category name to list tracing (options: {", ".join(TRACE_CAT_MAP.values())})')
    p_traces_list.set_defaults(func=traces_list)

    p_graceful_cleanup = subparsers.add_parser('graceful-cleanup',
                                               help='Have reffs server gracefully cleanup and exit')
    p_graceful_cleanup.set_defaults(func=graceful_cleanup)

    p_heartbeat = subparsers.add_parser('heartbeat',
                                        help='Manage the heartbeat for reffs server')
    p_heartbeat.add_argument('--period',
                             dest='period',
                             required=False,
                             type=int,
                             help='Set the heartbeat period in seconds')
    p_heartbeat.set_defaults(func=heartbeat)

    p_io_contexts_list = subparsers.add_parser('io-contexts-list',
                                               help='List the io contexts')
    p_io_contexts_list.add_argument('--fd',
                                    dest='fd',
                                    required=False,
                                    type=int,
                                    help='File descriptor socket is listening on, -1 for inactive, 0 for all')
    p_io_contexts_list.add_argument('--op',
                                    type=str,
                                    choices=list(OP_TYPE_MAP.values()),
                                    help=f'Type of operation to display (options: {", ".join(OP_TYPE_MAP.values())})')
    p_io_contexts_list.add_argument('--state',
                                    type=str,
                                    choices=list(CONTEXT_STATE_MAP.values()),
                                    help=f'Type of operation to display (options: {", ".join(CONTEXT_STATE_MAP.values())})')
    p_io_contexts_list.set_defaults(func=io_contexts_list, fd=0, op='all', state='all')

    p_fd_infos_list = subparsers.add_parser('fd-infos-list',
                                            help='List the fd listners')
    p_fd_infos_list.add_argument('--fd',
                                 dest='fd',
                                 required=False,
                                 type=int,
                                 help='File descriptor socket is listening on, -1 for inactive, 0 for all')
    p_fd_infos_list.set_defaults(func=fd_infos_list, fd=0)

    p_fs_usage = subparsers.add_parser('fs-usage',
                                       help='Get internal/external filesystem usage')
    a_legible = p_fs_usage.add_mutually_exclusive_group(required=False)
    a_legible.add_argument('--not_human_readable',
                           help='Do not provide sizes in human readable form',
                           dest='human_readable',
                           action='store_false')
    a_legible.add_argument('--human_readable',
                           help='Provide sizes in human readable form',
                           dest='human_readable',
                           action='store_true')
    p_fs_usage.add_argument('--mount-path',
                            dest='mount_path',
                            required=False,
                            type=str,
                            help='Optional path to mount point for comparison')
    p_fs_usage.set_defaults(func=fs_usage,human_readable=True)

    p_nfs4_op_stats = subparsers.add_parser('nfs4-op-stats',
                                            help='Get NFS4 per-op statistics')
    p_nfs4_op_stats.set_defaults(func=nfs4_op_stats)

    p_layout_errors = subparsers.add_parser('layout-errors',
                                            help='Get layout error statistics (global, per-dstore, per-client)')
    p_layout_errors.set_defaults(func=layout_errors)

    # Superblock management commands
    p_sb_list = subparsers.add_parser('sb-list', help='List all superblocks')
    p_sb_list.set_defaults(func=sb_list_cmd)

    p_sb_create = subparsers.add_parser('sb-create', help='Create a new superblock (server assigns ID)')
    p_sb_create.add_argument('--path', type=str, required=True, help='Export path (e.g., /secure)')
    p_sb_create.add_argument('--storage', type=str, default='ram',
                             choices=list(STORAGE_TYPE_NAME_TO_ID.keys()),
                             help='Storage backend type (default: ram)')
    p_sb_create.set_defaults(func=sb_create_cmd)

    p_sb_mount = subparsers.add_parser('sb-mount', help='Mount a superblock at its path')
    p_sb_mount.add_argument('--id', type=int, required=True, help='Superblock ID')
    p_sb_mount.add_argument('--path', type=str, required=True, help='Mount path')
    p_sb_mount.set_defaults(func=sb_mount_cmd)

    p_sb_unmount = subparsers.add_parser('sb-unmount', help='Unmount a superblock')
    p_sb_unmount.add_argument('--id', type=int, required=True, help='Superblock ID')
    p_sb_unmount.set_defaults(func=sb_unmount_cmd)

    p_sb_destroy = subparsers.add_parser('sb-destroy', help='Destroy a superblock')
    p_sb_destroy.add_argument('--id', type=int, required=True, help='Superblock ID')
    p_sb_destroy.set_defaults(func=sb_destroy_cmd)

    p_sb_get = subparsers.add_parser('sb-get', help='Get superblock info')
    p_sb_get.add_argument('--id', type=int, required=True, help='Superblock ID')
    p_sb_get.set_defaults(func=sb_get_cmd)

    p_sb_set_flavors = subparsers.add_parser('sb-set-flavors', help='Set security flavors on a superblock')
    p_sb_set_flavors.add_argument('--id', type=int, required=True, help='Superblock ID')
    p_sb_set_flavors.add_argument('--flavors', nargs='+', type=str, required=True,
                                  choices=list(AUTH_FLAVOR_NAME_TO_ID.keys()),
                                  help='Security flavors (e.g., sys krb5)')
    p_sb_set_flavors.set_defaults(func=sb_set_flavors_cmd)

    p_sb_lint = subparsers.add_parser('sb-lint-flavors', help='Check flavor consistency')
    p_sb_lint.set_defaults(func=sb_lint_flavors_cmd)

    # Identity management
    p_id_domains = subparsers.add_parser('identity-domain-list', help='List identity domains')
    p_id_domains.set_defaults(func=identity_domain_list_cmd)

    p_id_maps = subparsers.add_parser('identity-map-list', help='List identity mappings')
    p_id_maps.set_defaults(func=identity_map_list_cmd)

    p_id_remove = subparsers.add_parser('identity-map-remove', help='Remove an identity mapping')
    p_id_remove.add_argument('--from-id', required=True, help='reffs_id to remove (hex: 0x...)')
    p_id_remove.set_defaults(func=identity_map_remove_cmd)

    argcomplete.autocomplete(parser)
    return parser.parse_args()


def main():
    args = parse_args()

    # Added check for function attribute
    if not hasattr(args, 'func'):
        print("Error: No command specified")
        sys.exit(1)

    # Time measurement
    ts = None
    if args.time:
        ts = time.time()

    # Execute the requested function
    args.func(Probe1Client(args.host, args.port), args)

    # Print duration if timing was requested
    if args.time:
        te = time.time()
        duration = te - ts
        if not args.json:
            print(f'Time elapsed: {duration:.2f} seconds')

if __name__ == '__main__':
    main()
