import sys
import os
import argparse
import argcomplete
import struct
import time
import ipaddress

# Try both naming conventions to handle both local and installed versions
try:
    # First try the installed package path
    from reffs.probe1_xdr_type import *
    from reffs.probe1_xdr_const import *
    from reffs.probe_client import Probe1Client
except ModuleNotFoundError:
    # If that fails, try the local development path
    script_dir = os.path.dirname(os.path.abspath(__file__))
    if script_dir not in sys.path:
        sys.path.insert(0, script_dir)

    # Make sure __init__.py exists
    init_file = os.path.join(script_dir, "reffs", "__init__.py")
    if not os.path.exists(init_file):
        with open(init_file, 'w') as f:
            pass  # Create empty file

    # Try with the XDR naming convention
    from reffs.probe1_xdr_type import *
    from reffs.probe1_xdr_const import *
    from reffs.probe_client import Probe1Client

PROGRAM_MAP = {
    100003: 'nfs',
    100005: 'mount',
    211768: 'probe'
}

PROGRAM_NAME_TO_ID = {name: id for id, name in PROGRAM_MAP.items()}

TRACE_CAT_MAP = {
    PROBE1_TRACE_CAT_GENERAL: 'general',
    PROBE1_TRACE_CAT_IO: 'io',
    PROBE1_TRACE_CAT_RPC: 'rpc',
    PROBE1_TRACE_CAT_NFS: 'nfs',
    PROBE1_TRACE_CAT_NLM: 'nlm',
    PROBE1_TRACE_CAT_FS: 'fs',
    PROBE1_TRACE_CAT_ALL: 'all'
}

TRACE_CAT_NAME_TO_ID = {name: id for id, name in TRACE_CAT_MAP.items()}

OP_TYPE_MAP = {
    PROBE1_OP_TYPE_ACCEPT : 'accept',
    PROBE1_OP_TYPE_READ : 'read',
    PROBE1_OP_TYPE_WRITE : 'write',
    PROBE1_OP_TYPE_CONNECT : 'connect',
    PROBE1_OP_TYPE_RPC_REQ : 'rpc_req',
    PROBE1_OP_TYPE_HEARTBEAT : 'heartbeat',
    PROBE1_OP_TYPE_ALL : 'all'
}

OP_TYPE_NAME_TO_ID = {name: id for id, name in OP_TYPE_MAP.items()}

context_state_all = (PROBE1_IO_CONTEXT_ENTRY_STATE_ACTIVE |
                     PROBE1_IO_CONTEXT_ENTRY_STATE_MARKED_DESTROYED |
                     PROBE1_IO_CONTEXT_ENTRY_STATE_PENDING_FREE)

CONTEXT_STATE_MAP = {
    PROBE1_IO_CONTEXT_ENTRY_STATE_ACTIVE : 'active',
    PROBE1_IO_CONTEXT_ENTRY_STATE_MARKED_DESTROYED : 'destroyed',
    PROBE1_IO_CONTEXT_ENTRY_STATE_PENDING_FREE : 'pending',
    context_state_all : 'all'
}

CONTEXT_STATE_NAME_TO_ID = {name: id for id, name in CONTEXT_STATE_MAP.items()}

def probe_error_handler(ret):
    if ret == PROBE1_OK:
        return

    print(f'Error: {ret}')
    sys.exit(ret)


def probe_null(client, args):
    res = client.probe_null()
    print("Null procedure completed successfully")


def print_stats(pp, args):
    print(f'{"OP":<10} {"Name":<15} {"Calls":<10} {"Errors":<10} {"Max Duration":<15} {"Total Duration":<15} {"Average Duration":<15}')

    for po in sorted(pp.pp_ops, key=lambda po: po.po_op):
        if po.po_calls:
            avg_dur = po.po_total_duration / po.po_calls
        else:
            avg_dur = 0
        print(f'{po.po_op:<10} {po.po_name.decode():<15} {po.po_calls:<10} {po.po_errors:<10} {po.po_max_duration:<15} {po.po_total_duration:<15} {avg_dur:<15}')

    if args.histogram:
        print("\n--- Histogram Data (Counts) ---")
        print(f"\n{'OP':<5} {'Name':<15} {'<1ms':<10} {'1-10ms':<10} {'10-100ms':<10} {'100ms-1s':<10} {'1-10s':<10} {'≥10s':<10}")

        for po in sorted(pp.pp_ops, key=lambda po: po.po_op):
            if po.po_calls > 0:  # Only show operations that were called
                print(f'{po.po_op:<5} '
                      f'{po.po_name.decode():<15} '
                      f'{po.po_bucket_1ms:<10} '
                      f'{po.po_bucket_10ms:<10} '
                      f'{po.po_bucket_100ms:<10} '
                      f'{po.po_bucket_1s:<10} '
                      f'{po.po_bucket_10s:<10} '
                      f'{po.po_bucket_rest:<10}')

    if args.percentages:
        print("\n--- Histogram Data (Percentages) ---")
        print(f"\n{'OP':<5} {'Name':<15} {'<1ms':<10} {'1-10ms':<10} {'10-100ms':<10} {'100ms-1s':<10} {'1-10s':<10} {'≥10s':<10}")

        for po in sorted(pp.pp_ops, key=lambda po: po.po_op):
            if po.po_calls > 0:  # Only show operations that were called
                total = po.po_calls

                # Calculate percentages
                pct_1ms = (po.po_bucket_1ms / total) * 100
                pct_10ms = (po.po_bucket_10ms / total) * 100
                pct_100ms = (po.po_bucket_100ms / total) * 100
                pct_1s = (po.po_bucket_1s / total) * 100
                pct_10s = (po.po_bucket_10s / total) * 100
                pct_rest = (po.po_bucket_rest / total) * 100

                print(f'{po.po_op:<5} '
                      f'{po.po_name.decode():<15} '
                      f'{pct_1ms:6.1f}% '
                      f'{pct_10ms:6.1f}% '
                      f'{pct_100ms:6.1f}% '
                      f'{pct_1s:6.1f}% '
                      f'{pct_10s:6.1f}% '
                      f'{pct_rest:6.1f}%')

    if args.histogram or args.percentages:
        print("\n--- Percentile Statistics (ns) ---")
        print(f"\n{'OP':<5} {'Name':<15} {'Min':<15} {'Median':<15} {'90th':<15} {'99th':<15} {'99.9th':<15} {'Max':<15} {'Mean':<15}")

        for po in sorted(pp.pp_ops, key=lambda po: po.po_op):
            if po.po_calls > 0:
                print(f'{po.po_op:<5} '
                      f'{po.po_name.decode():<15} '
                      f'{po.po_min_ns:<15} '
                      f'{po.po_median_ns:<15} '
                      f'{po.po_p90_ns:<15} '
                      f'{po.po_p99_ns:<15} '
                      f'{po.po_p999_ns:<15} '
                      f'{po.po_max_ns:<15} '
                      f'{po.po_mean_ns:<15}')


def stats_gather(client, args):
    if args.program_id:
        program_id = args.program_id
    elif args.program_name:
        program_id = PROGRAM_NAME_TO_ID[args.program_name]

    res = client.stats_gather(program_id, args.version)
    probe_error_handler(res.psgr_status)

    pp = res.psgr_resok.psgr_program

    print(f'Reply Errors = {pp.pp_replied_errors}')
    print(f'Reject Errors = {pp.pp_rejected_errors}')
    print(f'Accept Errors = {pp.pp_accepted_errors}')
    print(f'Auth Errors = {pp.pp_authed_errors}')

    print_stats(pp, args)


def context(client, args):
    res = client.context()
    probe_error_handler(res.pcr_status)

    resok = res.pcr_resok

    print(f'Created          = {resok.pcr_created}')
    print(f'Freed            = {resok.pcr_freed}')
    print(f'Active Cancelled = {resok.pcr_active_cancelled}')
    print(f'Active Destroyed = {resok.pcr_active_destroyed}')
    print(f'Cancelled Freed  = {resok.pcr_cancelled_freed}')
    print(f'Destroyed Freed  = {resok.pcr_destroyed_freed}')


def rpc_dump_set(client, args):
    res = client.rpc_dump_set(args.dump)
    probe_error_handler(res)


def trace_set(client, args):
    category = TRACE_CAT_NAME_TO_ID[args.category]
    res = client.trace_set(category, args.tracing)
    probe_error_handler(res)


def print_trace_categories(trace_list):
    print(f"{'Category':<10} {'Status':<6}")
    print("-" * 17)
    for trace in sorted(trace_list, key=lambda t: t.ptl_cat):
        category_name = TRACE_CAT_MAP.get(trace.ptl_cat, "unknown")
        status = "Set" if trace.ptl_set else "Unset"
        print(f"{category_name:<10} {status:<6}")


def traces_list(client, args):
    category = TRACE_CAT_NAME_TO_ID[args.category]
    res = client.traces_list(category)
    probe_error_handler(res.tlr_status)

    print_trace_categories(res.tlr_resok.tlr_list)


def graceful_cleanup(client, args):
    res = client.graceful_cleanup()
    probe_error_handler(res)


def heartbeat(client, args):
    if args.period is None:
        period = 0
        period_set = False
    else:
        period = args.period
        period_set = True

    res = client.heartbeat(period, period_set)
    probe_error_handler(res.hbr_status)

    print(f"Heartbeat peiod: {res.hbr_resok.hbr_period}")


def decode_io_context_state(state):
    flags = []
    if state & PROBE1_IO_CONTEXT_ENTRY_STATE_ACTIVE:
        flags.append("ACTIVE")
    if state & PROBE1_IO_CONTEXT_ENTRY_STATE_MARKED_DESTROYED:
        flags.append("DESTROYED")
    if state & PROBE1_IO_CONTEXT_ENTRY_STATE_PENDING_FREE:
        flags.append("PENDING_FREE")
    if state & PROBE1_IO_CONTEXT_DIRECT_TLS_DATA:
        flags.append("TLS_DATA")
    if state & PROBE1_IO_CONTEXT_TLS_BIO_PROCESSED:
        flags.append("TLS_BIO")
    return ",".join(flags) if flags else "NONE"


def print_io_contexts(resok):
    print(f"{'ID':<12} {'FD':<4} {'Op':<10} {'XID':<10} {'Len':<10} {'Pos':<10} "
          f"{'Exp Len':<10} {'State':<32} {'Count':<10} {'Age (s)'}")

    now_sec = resok.iclr_now.seconds
    now_nsec = resok.iclr_now.nseconds

    for ctx in sorted(resok.iclr_pic, key=lambda ctx: ctx.pic_id):
        state_str = decode_io_context_state(ctx.pic_state)
        op_type = OP_TYPE_MAP.get(ctx.pic_op_type, "unknown")

        delta_sec = now_sec - ctx.pic_action_time.seconds
        delta_nsec = now_nsec - ctx.pic_action_time.nseconds
        if delta_nsec < 0:
            delta_sec -= 1
            delta_nsec += 1_000_000_000
        age = f"{delta_sec}.{delta_nsec:09}"

        print(f"{ctx.pic_id:<12} {ctx.pic_fd:<4} {op_type:<10} "
              f"0x{ctx.pic_xid:08x} {ctx.pic_buffer_len:<10} {ctx.pic_position:<10} "
              f"{ctx.pic_expected_len:<10} {state_str:<32} {ctx.pic_count:<10} {age}")


def io_contexts_list(client, args):
    op = OP_TYPE_NAME_TO_ID[args.op]

    state = CONTEXT_STATE_NAME_TO_ID[args.state]

    res = client.io_contexts_list(args.fd, op, state)
    probe_error_handler(res.iclr_status)

    print_io_contexts(res.iclr_resok)


def decode_probe1_address_string(addr_bytes):
    try:
        s = addr_bytes.decode('utf-8').rstrip('\x00')
    except Exception:
        return ("<decode-error>", 0)

    parts = s.rsplit('.', 2)
    if len(parts) < 3:
        return (s, 0)

    ip_str = '.'.join(parts[:-2])
    try:
        port = (int(parts[-2]) << 8) | int(parts[-1])
    except ValueError:
        return (s, 0)

    try:
        ip_obj = ipaddress.ip_address(ip_str)
        ip_expanded = ip_obj.exploded
    except ValueError:
        ip_expanded = ip_str

    return (ip_expanded, port)


def print_fd_infos(fd_infos):
    print(f"{'FD':<4} {'Server Port':<12} {'Client Port':<12} {'Client'}")
    for fd in sorted(fd_infos, key=lambda fd: fd.pf_fd):
        ip, port = decode_probe1_address_string(fd.pf_client)
        print(f"{fd.pf_fd:<4} {fd.pf_server_port:<12} {port:<12} {ip}")


def fd_infos_list(client, args):
    res = client.fd_infos_list(args.fd)
    probe_error_handler(res.filr_status)

    print_fd_infos(res.filr_resok.filr_pf)


def format_size(size_bytes, human_readable=False):
    if not human_readable:
        return str(size_bytes)

    if size_bytes == 0:
        return "0B"

    units = ["B", "K", "M", "G", "T", "P", "E"]
    i = 0
    size = float(size_bytes)

    while size >= 1024 and i < len(units) - 1:
        size /= 1024.0
        i += 1

    # Match typical du -h style formatting
    if size >= 10 or size.is_integer():
        return f"{int(size)}{units[i]}"
    else:
        return f"{size:.1f}{units[i]}"


def fs_usage(client, args):
    res = client.fs_usage(args.human_readable, args.mount_path if args.mount_path else "")
    probe_error_handler(res.fur_status)

    resok = res.fur_resok
    hr = args.human_readable

    mount_stats = None
    if args.mount_path:
        try:
            import os
            sv = os.statvfs(args.mount_path)
            mount_stats = {
                'total_bytes': sv.f_blocks * sv.f_frsize,
                'free_bytes': sv.f_bavail * sv.f_frsize,
                'used_bytes': (sv.f_blocks - sv.f_bfree) * sv.f_frsize,
                'total_files': sv.f_files,
                'free_files': sv.f_ffree,
                'used_files': sv.f_files - sv.f_ffree
            }
        except Exception as e:
            print(f"Warning: Could not get stats for mount path {args.mount_path}: {e}")

    if mount_stats:
        header = f"{'Metric':<15} {'Server (RPC)':>20} {'Mount (statvfs)':>20} {'Diff':>15}"
        print(header)
        print("-" * len(header))

        metrics = [
            ('Total Bytes', resok.fur_total_bytes, mount_stats['total_bytes'], True),
            ('Used Bytes', resok.fur_used_bytes, mount_stats['used_bytes'], True),
            ('Free Bytes', resok.fur_free_bytes, mount_stats['free_bytes'], True),
            ('Total Inodes', resok.fur_total_files, mount_stats['total_files'], False),
            ('Used Inodes', resok.fur_used_files, mount_stats['used_files'], False),
            ('Free Inodes', resok.fur_free_files, mount_stats['free_files'], False),
        ]

        for label, r_val, m_val, is_bytes in metrics:
            r_str = format_size(r_val, hr if is_bytes else False)
            m_str = format_size(m_val, hr if is_bytes else False)
            diff = r_val - m_val
            diff_str = format_size(diff, hr if is_bytes else False)
            print(f"{label:<15} {r_str:>20} {m_str:>20} {diff_str:>15}")
    else:
        print("Filesystem Usage (Internal/External):")
        print("  Bytes:")
        print(f"    Total: {format_size(resok.fur_total_bytes, hr):>15}")
        print(f"    Used:  {format_size(resok.fur_used_bytes, hr):>15}")
        print(f"    Free:  {format_size(resok.fur_free_bytes, hr):>15}")
        print("  Inodes:")
        print(f"    Total: {resok.fur_total_files:>15}")
        print(f"    Used:  {resok.fur_used_files:>15}")
        print(f"    Free:  {resok.fur_free_files:>15}")


def parse_args():
    parser = argparse.ArgumentParser(description='Probe reffs servers')

    parser.add_argument('--port',
                        help=f'set port, default is {PROBE_PORT}',
                        required=False,
                        type=int,
                        default=PROBE_PORT)
    parser.add_argument('--host',
                        help='set host, default is ::1',
                        required=False,
                        default='::1')
    parser.add_argument('--time',
                        help='Time the call',
                        required=False,
                        action='store_true',
                        default=False)

    subparsers = parser.add_subparsers(help='sub-command help', dest='command')
    subparsers.required = True  # Make subcommand required

    p_null = subparsers.add_parser('null',
                                   help='Ping the server')
    p_null.set_defaults(func=probe_null)

    p_gather = subparsers.add_parser('stats-gather',
                                     help='Gather stats for an RPC program')
    a_program = p_gather.add_mutually_exclusive_group(required=True)

    a_program.add_argument('--program-id',
                           dest='program_id',
                           type=int,
                           choices=list(PROGRAM_MAP.keys()),
                           help=f'Program id to gather stats (options: {", ".join(map(str, PROGRAM_MAP.keys()))})')

    a_program.add_argument('--program-name',
                           dest='program_name',
                           type=str,
                           choices=list(PROGRAM_MAP.values()),
                           help=f'Program name to gather stats (options: {", ".join(PROGRAM_MAP.values())})')

    p_gather.add_argument('--version',
                          dest='version',
                          required=True,
                          type=int,
                          help='Program version to gather stats')

    p_gather.add_argument('--histogram',
                          dest='histogram',
                          action='store_true',
                          help='Display the histogram (default is not to show)')

    p_gather.add_argument('--percentages',
                          dest='percentages',
                          action='store_true',
                          help='Display histogram data as percentages (default is not to show)')

    p_gather.set_defaults(func=stats_gather, histogram=False)

    p_context = subparsers.add_parser('context',
                                      help='Get the context stats')
    p_context.set_defaults(func=context)

    p_rpc_dump_set = subparsers.add_parser('rpc-dump',
                                           help='Dump RPC packets')
    a_dumper = p_rpc_dump_set.add_mutually_exclusive_group(required=True)
    a_dumper.add_argument('--set',
                          help='Set RPC dumping',
                          dest='dump',
                          required=False,
                          action='store_true')
    a_dumper.add_argument('--unset',
                          help='Unset RPC dumping',
                          dest='dump',
                          required=False,
                          action='store_false')
    p_rpc_dump_set.set_defaults(func=rpc_dump_set)

    p_trace_set = subparsers.add_parser('trace-set',
                                        help='Set the tracing for a category')
    a_trace_set = p_trace_set.add_mutually_exclusive_group(required=True)
    a_trace_set.add_argument('--set',
                             help='Set TRACE category tracing',
                             dest='tracing',
                             required=False,
                             action='store_true')
    a_trace_set.add_argument('--unset',
                             help='Unset TRACE category tracing',
                             dest='tracing',
                             required=False,
                             action='store_false')
    p_trace_set.add_argument('--category',
                             type=str,
                             choices=list(TRACE_CAT_MAP.values()),
                             help=f'Category name to set tracing (options: {", ".join(TRACE_CAT_MAP.values())})')
    p_trace_set.set_defaults(func=trace_set)

    p_traces_list = subparsers.add_parser('traces-list',
                                          help='List the tracing for a category')
    p_traces_list.add_argument('--category',
                              type=str,
                              choices=list(TRACE_CAT_MAP.values()),
                              help=f'Category name to list tracing (options: {", ".join(TRACE_CAT_MAP.values())})')
    p_traces_list.set_defaults(func=traces_list)

    p_graceful_cleanup = subparsers.add_parser('graceful-cleanup',
                                               help='Have reffs server gracefully cleanup and exit')
    p_graceful_cleanup.set_defaults(func=graceful_cleanup)

    p_heartbeat = subparsers.add_parser('heartbeat',
                                        help='Manage the heartbeat for reffs server')
    p_heartbeat.add_argument('--period',
                             dest='period',
                             required=False,
                             type=int,
                             help='Set the heartbeat period in seconds')
    p_heartbeat.set_defaults(func=heartbeat)

    p_io_contexts_list = subparsers.add_parser('io-contexts-list',
                                               help='List the io contexts')
    p_io_contexts_list.add_argument('--fd',
                                    dest='fd',
                                    required=False,
                                    type=int,
                                    help='File descriptor socket is listening on, -1 for inactive, 0 for all')
    p_io_contexts_list.add_argument('--op',
                                    type=str,
                                    choices=list(OP_TYPE_MAP.values()),
                                    help=f'Type of operation to display (options: {", ".join(OP_TYPE_MAP.values())})')
    p_io_contexts_list.add_argument('--state',
                                    type=str,
                                    choices=list(CONTEXT_STATE_MAP.values()),
                                    help=f'Type of operation to display (options: {", ".join(CONTEXT_STATE_MAP.values())})')
    p_io_contexts_list.set_defaults(func=io_contexts_list, fd=0, op='all', state='all')

    p_fd_infos_list = subparsers.add_parser('fd-infos-list',
                                            help='List the fd listners')
    p_fd_infos_list.add_argument('--fd',
                                 dest='fd',
                                 required=False,
                                 type=int,
                                 help='File descriptor socket is listening on, -1 for inactive, 0 for all')
    p_fd_infos_list.set_defaults(func=fd_infos_list, fd=0)

    p_fs_usage = subparsers.add_parser('fs-usage',
                                       help='Get internal/external filesystem usage')
    p_fs_usage.add_argument('mount_path',
                            nargs='?',
                            help='Optional path to mount point for comparison')
    a_legible = p_fs_usage.add_mutually_exclusive_group(required=False)
    a_legible.add_argument('--not_human_readable',
                           help='Do not provide sizes in human readable form',
                           dest='human_readable',
                           action='store_false')
    a_legible.add_argument('--human_readable',
                           help='Provide sizes in human readable form',
                           dest='human_readable',
                           action='store_true')
    p_fs_usage.set_defaults(func=fs_usage,human_readable=True)

    argcomplete.autocomplete(parser)
    return parser.parse_args()


def main():
    args = parse_args()

    # Added check for function attribute
    if not hasattr(args, 'func'):
        print("Error: No command specified")
        sys.exit(1)

    # Time measurement
    ts = None
    if args.time:
        ts = time.time()

    # Execute the requested function
    args.func(Probe1Client(args.host, args.port), args)

    # Print duration if timing was requested
    if args.time:
        te = time.time()
        duration = te - ts
        print(f'Time elapsed: {duration:.2f} seconds')

if __name__ == '__main__':
    main()
