def heartbeat(client, args):
    if args.period is None:
        period = 0
        period_set = False
    else:
        period = args.period
        period_set = True

    res = client.heartbeat(period, period_set)
    probe_error_handler(res.hbr_status)

    if args.json:
        json_output(res.hbr_resok)
        return

    print(f"Heartbeat period: {res.hbr_resok.hbr_period}")


def decode_io_context_state(state):
    flags = []
    if state & PROBE1_IO_CONTEXT_ENTRY_STATE_ACTIVE:
        flags.append("ACTIVE")
    if state & PROBE1_IO_CONTEXT_ENTRY_STATE_MARKED_DESTROYED:
        flags.append("DESTROYED")
    if state & PROBE1_IO_CONTEXT_ENTRY_STATE_PENDING_FREE:
        flags.append("PENDING_FREE")
    if state & PROBE1_IO_CONTEXT_DIRECT_TLS_DATA:
        flags.append("TLS_DATA")
    if state & PROBE1_IO_CONTEXT_TLS_BIO_PROCESSED:
        flags.append("TLS_BIO")
    return ",".join(flags) if flags else "NONE"


def print_io_contexts(resok):
    print(f"{'ID':<12} {'FD':<4} {'Op':<10} {'XID':<10} {'Len':<10} {'Pos':<10} "
          f"{'Exp Len':<10} {'State':<32} {'Count':<10} {'Age (s)'}")

    now_sec = resok.iclr_now.seconds
    now_nsec = resok.iclr_now.nseconds

    for ctx in sorted(resok.iclr_pic, key=lambda ctx: ctx.pic_id):
        state_str = decode_io_context_state(ctx.pic_state)
        op_type = OP_TYPE_MAP.get(ctx.pic_op_type, "unknown")

        delta_sec = now_sec - ctx.pic_action_time.seconds
        delta_nsec = now_nsec - ctx.pic_action_time.nseconds
        if delta_nsec < 0:
            delta_sec -= 1
            delta_nsec += 1_000_000_000
        age = f"{delta_sec}.{delta_nsec:09}"

        print(f"{ctx.pic_id:<12} {ctx.pic_fd:<4} {op_type:<10} "
              f"0x{ctx.pic_xid:08x} {ctx.pic_buffer_len:<10} {ctx.pic_position:<10} "
              f"{ctx.pic_expected_len:<10} {state_str:<32} {ctx.pic_count:<10} {age}")


def io_contexts_list(client, args):
    op = OP_TYPE_NAME_TO_ID[args.op]

    state = CONTEXT_STATE_NAME_TO_ID[args.state]

    res = client.io_contexts_list(args.fd, op, state)
    probe_error_handler(res.iclr_status)

    if args.json:
        json_output(res.iclr_resok)
        return

    print_io_contexts(res.iclr_resok)


def decode_probe1_address_string(addr_bytes):
    try:
        s = addr_bytes.decode('utf-8').rstrip('\x00')
    except Exception:
        return ("<decode-error>", 0)

    parts = s.rsplit('.', 2)
    if len(parts) < 3:
        return (s, 0)

    ip_str = '.'.join(parts[:-2])
    try:
        port = (int(parts[-2]) << 8) | int(parts[-1])
    except ValueError:
        return (s, 0)

    try:
        ip_obj = ipaddress.ip_address(ip_str)
        ip_expanded = ip_obj.exploded
    except ValueError:
        ip_expanded = ip_str

    return (ip_expanded, port)


def print_fd_infos(fd_infos):
    print(f"{'FD':<4} {'Server Port':<12} {'Client Port':<12} {'Client'}")
    for fd in sorted(fd_infos, key=lambda fd: fd.pf_fd):
        ip, port = decode_probe1_address_string(fd.pf_client)
        print(f"{fd.pf_fd:<4} {fd.pf_server_port:<12} {port:<12} {ip}")


