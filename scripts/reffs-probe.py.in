    100005: 'mount',
    100021: 'nlm',
    100024: 'sm',
    211768: 'probe',
    304097: 'echo',
    304098: 'rcp'
}

PROGRAM_NAME_TO_ID = {name: id for id, name in PROGRAM_MAP.items()}

