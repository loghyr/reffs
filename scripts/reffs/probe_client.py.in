import struct
import time
from .probe1_xdr_type import *
from .probe1_xdr_const import *
from .probe1_xdr_pack import PROBE1_XDRPacker, PROBE1_XDRUnpacker
from .protocol_client import ProtocolClient

class Probe1Client(ProtocolClient):
    """
    Client implementation for Probe1.
    """
    # Define constants specific to this protocol
    PROG = PROBE_PROGRAM
    VERS = PROBE_V1
    DEFAULT_PORT = PROBE_PORT

    # Define the XDR packer/unpacker classes
    PackerClass = PROBE1_XDRPacker
    UnpackerClass = PROBE1_XDRUnpacker

    def __init__(self, host='localhost', port=None):
        super().__init__(host=host, port=port)

        # Protocol-specific initialization
        self.verifier = struct.pack('>d', time.time())

    def is_void_response_proc(self, procnum):
        """
        Override to specify which procedures return void responses.
        """
        return procnum == PROBEPROC1_NULL

    def probe_null(self):
        """Call the null procedure (procedure 0)."""
        return self.null()

    def stats_gather(self, program, version):
        """
        Gather statistics for a specific program and version.

        Args:
            program: Program number to gather stats for
            version: Version number to gather stats for

        Returns:
            STATS_GATHER1res object containing statistics
        """
        args = STATS_GATHER1args(program, version)
        return self.proc(PROBEPROC1_STATS_GATHER, args)

    def context(self):
        """
        Get context information from the server.

        Returns:
            CONTEXT1res object containing context information
        """
        return self.proc(PROBEPROC1_CONTEXT, response_type='CONTEXT1res')

    def rpc_dump_set(self, dump):
        """
        Set RPC dump level.

        Args:
            dump: An integer specifying the dump level (probe_dump1/unsigned int)

        Returns:
            probe_stat1 enum value
        """
        return self.proc(PROBEPROC1_RPC_DUMP_SET, dump, response_type='probe_stat1')

    def trace_set(self, category, tracing):
        """
        Set TRACE level for category

        Args:
            category: An integer specifying the category to set
                      Set to PROBE1_TRACE_CAT_ALL to set all.
            tracing: Set or unset the category

        Returns:
            probe_stat1 enum value
        """
        args = TRACE_SET1args(category, tracing)
        return self.proc(PROBEPROC1_TRACE_SET, args, response_type='probe_stat1')

    def traces_list(self, category):
        """
        Get TRACE levels for category

        Args:
            category: An integer specifying the category to list.
                      Set to PROBE1_TRACE_CAT_ALL to get all.

        Returns:
            TRACES_LIST1res object containing list of set values
        """
        return self.proc(PROBEPROC1_TRACES_LIST, category, response_type='TRACES_LIST1res')

    def graceful_cleanup(self):
        """
        Tell server to gracefully end

        Args:

        Returns:
            probe_stat1 enum value
        """
        return self.proc(PROBEPROC1_GRACEFUL_CLEANUP, response_type='probe_stat1')

    def heartbeat(self, period, period_set):
        """
        Tell server the heartbeat period

        Args:
            period: How long in seconds between heartbeats
            period_set: Whether we are setting the period or not

        Returns:
            HEARTBEAT1res object containing heartbeat info
        """
        args = HEARTBEAT1args(period, period_set)
        return self.proc(PROBEPROC1_HEARTBEAT, args, response_type='HEARTBEAT1res')

    def io_contexts_list(self, fd, op, state):
        """
        Get the io_context list from the server

        Args:
            fd: fd to match, 0 means all
            op: Which type of op to match
            state: Which state of the ic to match

        Returns:
            IO_CONTEXTS_LIST1res object containing array of matching ICs
        """
        args = IO_CONTEXTS_LIST1args(fd, op, state)
        return self.proc(PROBEPROC1_IO_CONTEXTS_LIST, args, response_type='IO_CONTEXTS_LIST1res')

    def fd_infos_list(self, fd):
        """
        Get the list of fds and what they are listening to

        Args:
            fd: fd to match, 0 means all

        Returns:
            FD_INFOS_LIST1res object containing array client information
        """
        args = FD_INFOS_LIST1args(fd)
        return self.proc(PROBEPROC1_FD_INFOS_LIST, args, response_type='FD_INFOS_LIST1res')

    def fs_usage(self):
        """
        Get filesystem usage from the server.

        Returns:
            FS_USAGE1res object containing filesystem usage information
        """
        return self.proc(PROBEPROC1_FS_USAGE, response_type='FS_USAGE1res')

    def nfs4_op_stats(self):
        """
        Get NFS4 per-op statistics from the server.

        Returns:
            NFS4_OP_STATS1res object containing per-op statistics
        """
        return self.proc(PROBEPROC1_NFS4_OP_STATS, response_type='NFS4_OP_STATS1res')

    def layout_errors(self):
        """
        Get layout error statistics (global, per-dstore, per-client).

        Returns:
            LAYOUT_ERRORS1res object containing layout error counts
        """
        return self.proc(PROBEPROC1_LAYOUT_ERRORS, response_type='LAYOUT_ERRORS1res')

    # ----------------------------------------------------------------
    # Superblock management ops (13-20)
    # ----------------------------------------------------------------

    def sb_list(self):
        """List all superblocks with id, path, state, flavors."""
        return self.proc(PROBEPROC1_SB_LIST, response_type='SB_LIST1res')

    def sb_create(self, path, storage_type=PROBE1_STORAGE_RAM):
        """Create a new superblock (server assigns id)."""
        if isinstance(path, str):
            path = path.encode('utf-8')
        args = SB_CREATE1args(path, storage_type)
        return self.proc(PROBEPROC1_SB_CREATE, args, response_type='SB_CREATE1res')

    def sb_mount(self, sb_id, path):
        """Mount a superblock at the given path."""
        if isinstance(path, str):
            path = path.encode('utf-8')
        args = SB_MOUNT1args(sb_id, path)
        return self.proc(PROBEPROC1_SB_MOUNT, args, response_type='probe_stat1')

    def sb_unmount(self, sb_id):
        """Unmount a superblock."""
        args = SB_UNMOUNT1args(sb_id)
        return self.proc(PROBEPROC1_SB_UNMOUNT, args, response_type='probe_stat1')

    def sb_destroy(self, sb_id):
        """Destroy a superblock (must be unmounted first)."""
        args = SB_DESTROY1args(sb_id)
        return self.proc(PROBEPROC1_SB_DESTROY, args, response_type='probe_stat1')

    def sb_get(self, sb_id):
        """Get superblock info by id."""
        args = SB_GET1args(sb_id)
        return self.proc(PROBEPROC1_SB_GET, args, response_type='SB_GET1res')

    def sb_set_flavors(self, sb_id, flavors):
        """Set security flavors on a superblock."""
        args = SB_SET_FLAVORS1args(sb_id, flavors)
        return self.proc(PROBEPROC1_SB_SET_FLAVORS, args, response_type='probe_stat1')

    def sb_set_layout_types(self, sb_id, layout_types):
        """Set pNFS layout types on a superblock (bitmask: 1=FFv1, 2=FFv2)."""
        args = SB_SET_LAYOUT_TYPES1args(sb_id, layout_types)
        return self.proc(PROBEPROC1_SB_SET_LAYOUT_TYPES, args,
                         response_type='probe_stat1')

    def sb_set_dstores(self, sb_id, dstore_ids):
        """Set per-export dstore binding (list of dstore IDs)."""
        args = SB_SET_DSTORES1args(sb_id, dstore_ids)
        return self.proc(PROBEPROC1_SB_SET_DSTORES, args,
                         response_type='probe_stat1')

    def sb_set_stripe_unit(self, sb_id, stripe_unit):
        """Set FFv1 stripe unit in bytes on a superblock (0 = whole-file CSM)."""
        args = SB_SET_STRIPE_UNIT1args(sb_id, stripe_unit)
        return self.proc(PROBEPROC1_SB_SET_STRIPE_UNIT, args,
                         response_type='probe_stat1')

    def inode_layout_list(self, sb_id, inum):
        """Read-only enumeration of an inode's mirror set.

        Returns INODE_LAYOUT_LIST1res with ill_lss_gen and the
        ill_mirrors[] array (each mirror has plm_dstore_id,
        plm_ds_fh, plm_size, plm_mtime_sec/nsec).  See
        .claude/design/mirror-lifecycle.md "Slice A".
        """
        args = INODE_LAYOUT_LIST1args(sb_id, inum)
        return self.proc(PROBEPROC1_INODE_LAYOUT_LIST, args,
                         response_type='INODE_LAYOUT_LIST1res')

    # Slice B: dstore lifecycle.
    def dstore_list(self):
        """Operator dashboard for the dstore pool.  Returns
        DSTORE_LIST1res with one probe_dstore_info1 per dstore
        (id, address, path, state, drained, lost, instance_count,
        runway_capacity).  See .claude/design/mirror-lifecycle.md
        "Slice B"."""
        return self.proc(PROBEPROC1_DSTORE_LIST,
                         response_type='DSTORE_LIST1res')

    def dstore_drain(self, dstore_id):
        """Mark a dstore as drained (no new placements; existing
        instances stay reachable).  Idempotent."""
        args = DSTORE_DRAIN1args(dstore_id)
        return self.proc(PROBEPROC1_DSTORE_DRAIN, args,
                         response_type='probe_stat1')

    def dstore_undrain(self, dstore_id):
        """Clear the drained flag on a dstore.  Already-migrated
        files stay on their new dstores; in-flight slice-E workers
        detect the UNDRAIN at the post-ADD checkpoint and abort
        the REMOVE."""
        args = DSTORE_UNDRAIN1args(dstore_id)
        return self.proc(PROBEPROC1_DSTORE_UNDRAIN, args,
                         response_type='probe_stat1')

    def dstore_instance_count(self, dstore_id):
        """Read the cached count of (sb, inum) entries indexed against
        this dstore (mirror-lifecycle Slice B'').  Admin's fast
        'is the drain complete?' query.  Returns
        DSTORE_INSTANCE_COUNT1res; success branch carries dicr_count.
        """
        args = DSTORE_INSTANCE_COUNT1args(dstore_id)
        return self.proc(PROBEPROC1_DSTORE_INSTANCE_COUNT, args,
                         response_type='DSTORE_INSTANCE_COUNT1res')

    def sb_set_client_rules(self, sb_id, rules):
        """Set per-client export policy rules on a superblock.

        rules is a list of probe_client_rule1 objects.  The caller is
        responsible for converting flavor name strings to PROBE1_AUTH_*
        integer values before calling this method.
        """
        args = SB_SET_CLIENT_RULES1args(sb_id, rules)
        return self.proc(PROBEPROC1_SB_SET_CLIENT_RULES, args,
                         response_type='probe_stat1')

    def sb_lint_flavors(self):
        """Check flavor consistency across all mounted exports."""
        return self.proc(PROBEPROC1_SB_LINT_FLAVORS, response_type='SB_LINT_FLAVORS1res')

    # ----------------------------------------------------------------
    # Identity management ops
    # ----------------------------------------------------------------

    def identity_domain_list(self):
        """List all identity domains."""
        return self.proc(PROBEPROC1_IDENTITY_DOMAIN_LIST,
                         response_type='IDENTITY_DOMAIN_LIST1res')

    def identity_map_list(self):
        """List all identity mappings."""
        return self.proc(PROBEPROC1_IDENTITY_MAP_LIST,
                         response_type='IDENTITY_MAP_LIST1res')

    def identity_map_remove(self, from_id):
        """Remove an identity mapping by reffs_id."""
        args = IDENTITY_MAP_REMOVE1args(from_id)
        return self.proc(PROBEPROC1_IDENTITY_MAP_REMOVE, args,
                         response_type='probe_stat1')
