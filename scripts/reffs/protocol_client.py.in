from .pynfs.rpc import rpc
import logging
import time

class ProtocolClient(rpc.Client):
    """
    A generic base class for RPC protocol clients.
    Extends rpc.Client to provide common functionality for specific protocol implementations.
    """

    # These should be overridden by subclasses
    PROG = None
    VERS = None
    DEFAULT_PORT = None
    PackerClass = None
    UnpackerClass = None

    def __init__(self, host='localhost', port=None, prog=None, vers=None):
        # Allow overriding class constants at instance level
        prog = prog or self.PROG
        vers = vers or self.VERS

        if prog is None or vers is None:
            raise ValueError("Program number and version must be specified")

        # Initialize the RPC client with AUTH_NONE by default
        rpc.Client.__init__(self, prog, vers)

        # Set up default credentials (AUTH_NONE)
        self.default_cred = rpc.security.CredInfo()  # Uses AUTH_NONE by default

        self.server_address = (host, port or self.DEFAULT_PORT)
        self._pipe = None

        # Set up logging
        self.log = logging.getLogger(f"protocol.client.{self.__class__.__name__}")

    def get_pipe(self):
        """Get or create the connection to the server"""
        if not self._pipe or not self._pipe.is_active():
            self._pipe = self.connect(self.server_address)
        return self._pipe

    def proc_async(self, procnum, procarg=None, credinfo=None, pipe=None, checks=True):
        """
        Send an async RPC call and return the XID.

        Args:
            procnum: Procedure number to call
            procarg: Argument object for the procedure
            credinfo: Credentials info (defaults to AUTH_NONE)
            pipe: RPC pipe to use (creates one if None)
            checks: Whether to perform XDR validation checks

        Returns:
            xid: Transaction ID that can be used to retrieve the response
        """
        if credinfo is None:
            credinfo = self.default_cred
        if pipe is None:
            pipe = self.get_pipe()

        # Handle void arguments
        if procarg is None:
            # For void procedures, prepare an empty buffer or use appropriate packing
            return self.send_call(pipe, procnum, b'', credinfo)

        # Handle primitive types (like integers for RPC_DUMP_SET)
        if isinstance(procarg, (int, bool, float, str)):
            if self.PackerClass is None:
                raise NotImplementedError("PackerClass must be defined in the subclass")
            p = self.PackerClass(check_enum=checks, check_array=checks)

            # Choose the appropriate pack method based on the type
            if isinstance(procarg, int):
                p.pack_uint(procarg)
            elif isinstance(procarg, bool):
                p.pack_bool(procarg)
            elif isinstance(procarg, float):
                p.pack_double(procarg)
            elif isinstance(procarg, str):
                p.pack_string(procarg)

            return self.send_call(pipe, procnum, p.get_buffer(), credinfo)

        # Pack the arguments using the protocol-specific packer for complex types
        if self.PackerClass is None:
            raise NotImplementedError("PackerClass must be defined in the subclass")

        p = self.PackerClass(check_enum=checks, check_array=checks)
        arg_packer = getattr(p, f'pack_{procarg.__class__.__name__}')
        arg_packer(procarg)

        # Send the call and return the XID for later retrieval
        return self.send_call(pipe, procnum, p.get_buffer(), credinfo)

    def proc(self, procnum, procarg=None, response_type=None, **kwargs):
        """
        Send an RPC call and wait for the response.

        Args:
            procnum: Procedure number to call
            procarg: Argument object for the procedure
            response_type: Optional string specifying the response type name
            **kwargs: Additional arguments to pass to proc_async and listen

        Returns:
            The unpacked response object
        """
        xid = self.proc_async(procnum, procarg, **kwargs)
        pipe = kwargs.get("pipe", None)
        timeout = kwargs.get("timeout", 10.0)

        # If the procedure is defined as returning void, just wait for the response
        # and return the raw data without unpacking
        if self.is_void_response_proc(procnum):
            header, data = (pipe or self.get_pipe()).listen(xid, timeout)
            return data

        # If a specific response type was provided, use that
        if response_type:
            return self.listen_with_response_type(xid, response_type, pipe, timeout)

        # For procedures with void arguments but structured responses,
        # we still need to determine the response type somehow
        if procarg is None:
            raise ValueError("For procedures with void arguments, you must specify response_type")

        return self.listen(xid, procarg=procarg, pipe=pipe, timeout=timeout)

    def listen_with_response_type(self, xid, response_type, pipe=None, timeout=10.0):
        """
        Listen for a response using a specific response type name.

        Args:
            xid: Transaction ID from proc_async
            response_type: String specifying the response type name
            pipe: RPC pipe to use (uses the one from get_pipe() if None)
            timeout: How long to wait for a response

        Returns:
            The unpacked response object
        """
        if pipe is None:
            pipe = self.get_pipe()

        # Get the response
        header, data = pipe.listen(xid, timeout)

        if not data:
            return None

        # Unpack the response using the specific type
        p = self.UnpackerClass(data)
        res_unpacker = getattr(p, f'unpack_{response_type}')
        return res_unpacker()

    def is_void_response_proc(self, procnum):
        """
        Check if a procedure returns void.
        By default, only procedure 0 (NULL) returns void.
        Subclasses can override this to specify other void procedures.
        """
        return procnum == 0

    def listen(self, xid, procarg=None, pipe=None, timeout=10.0):
        """
        Wait for a response to a previous async call.

        Args:
            xid: Transaction ID from proc_async
            procarg: The argument object that was sent (used to determine response type)
            pipe: RPC pipe to use (uses the one from get_pipe() if None)
            timeout: How long to wait for a response

        Returns:
            The unpacked response object
        """
        if pipe is None:
            pipe = self.get_pipe()

        # Get the response
        header, data = pipe.listen(xid, timeout)

        if not data:
            return None

        # Unpack the response
        if self.UnpackerClass is None:
            raise NotImplementedError("UnpackerClass must be defined in the subclass")

        p = self.UnpackerClass(data)

        # Determine the response type from the argument type
        # This must be implemented by subclasses if the naming pattern differs
        resname = self.get_response_name(procarg.__class__.__name__)

        # Unpack the response
        res_unpacker = getattr(p, f'unpack_{resname}')
        data = res_unpacker()

        return data

    def get_response_name(self, argname):
        """
        Convert an argument class name to the corresponding response class name.
        Override this in subclasses if the naming pattern is different.

        Default implementation assumes: FOOargs -> FOOres
        """
        if argname.endswith('args'):
            return argname[:-4] + 'res'
        return argname + '_res'

    def null_async(self, data=b""):
        """Async null RPC call (useful for testing)"""
        return self.send_call(self.get_pipe(), 0, data, self.default_cred)

    def null(self, *args, **kwargs):
        """Synchronous null RPC call"""
        xid = self.null_async(*args, **kwargs)
        header, data = self.get_pipe().listen(xid, kwargs.get("timeout", 10.0))
        return data
