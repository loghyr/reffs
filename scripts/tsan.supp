#
# TSAN suppressions for known false positives.
#
# liburcu uses custom lock-free synchronization that TSAN cannot
# analyze.  These races are in liburcu internals, not reffs code.

race:liburcu-cds.so
race:liburcu.so
race:liburcu-mb.so
race:liburcu-memb.so
