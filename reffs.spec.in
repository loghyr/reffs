Summary: A Reference File System
Name: @PACKAGE@
Version: @VERSION@
Release: 1%{?dist}
Epoch: 1
License: GPL-2.0+
URL: http://www.tulsalabs.com/
Group: Development/System
Packager: Tom Haynes <loghyr@gmail.com>

Source: @PACKAGE@-@VERSION@.tar.bz2

BuildRequires: git
BuildRequires: autoreconf
BuildRequires: automake
BuildRequires: libtool
BuildRequires: userspace-rcu-devel
BuildRequires: libtirpc-devel
BuildRequires: check-devel
BuildRequires: libuuid-devel
BuildRequires: libev-devel
BuildRequires: xxhash-devel
BuildRequires: fuse-devel
BuildRequires: clang
BuildRequires: autoconf-archive
BuildRequires: make
BuildRequires: gcc
BuildRequires: clang-format
BuildRequires: rpcgen
BuildRequires: bear
BuildRequires: clang-tidy
BuildRequires: scan-build
BuildRequires: zlib-devel

Requires: check
Requires: fuse
Requires: libtirpc
Requires: zlib
Requires: libev
Requires: libuuid
Requires: pthreads
Requires: userspace-rcu
Requires: xxhash

Buildroot: %{_tmppath}/%{name}-root

%description 
The Reference File System (reffs) is:
1) A reference user land file system.
2) A reference NFSv3 server.
3) A reference NFSv3 client.
4) A reference NFSv4.1 server with Flex Files support.
5) A reference NFSv4.1 client with Flex Files support.
6) A reference Control Protocol which communicates between
   a reference NFSv3 server and a reference NFSv4.1 server
   with Flex Files support.

%bcond_with toolchain_clang

%if %{with toolchain_clang}
%global toolchain clang
%else
%global toolchain gcc
%endif

%global _lto_cflags %{nil}

%prep
%setup -q

%pre

%preun
%systemd_preun reffs-echo.service

%post
/sbin/ldconfig

%systemd_post reffs-echo.service

%postun
/sbin/ldconfig

%build
%if %{?_debug_enabled:1}%{!?_debug_enabled:0}
  %if %{_debug_enabled}==1
    %define _enable_debug --enable-debug
  %endif
%endif
%if %{?_asan_enabled:1}%{!?_asan_enabled:0}
  %if %{_asan_enabled}==1
    %define _enable_asan --enable-asan
  %endif
%endif
%if %{?_tsan_enabled:1}%{!?_tsan_enabled:0}
  %if %{_tsan_enabled}==1
    %define _enable_tsan --enable-tsan
  %endif
%endif
%if %{?_lsan_enabled:1}%{!?_lsan_enabled:0}
  %if %{_lsan_enabled}==1
    %define _enable_lsan --enable-lsan
  %endif
%endif
%if %{?_ubsan_enabled:1}%{!?_ubsan_enabled:0}
  %if %{_ubsan_enabled}==1
    %define _enable_ubsan --enable-ubsan
  %endif
%endif
%configure  %{?_enable_debug} %{?_enable_asan} %{?_enable_tsan} %{?_enable_lsan} %{?_enable_ubsan}
make %{?_smp_mflags}

%install
%make_install
rm -f %{buildroot}/%{_libdir}/*.la

%files
%defattr(-,root,root)
%doc README.md COPYING CONTRIBUTING INSTALL LICENSES/*
%{_bindir}/*
%{_includedir}/reffs/*
%{_libdir}/*.so*
%{_libdir}/*.a
%{_libdir}/pkgconfig/*
%{_unitdir}/*
%{python_sitelib}/reffs/*

%changelog
* Fri Nov  3 2023 Tom Haynes <loghyr@gmail.com> - 0.0.1
- First version being packaged
